# PostgreSQL — used by docker-compose to initialize the DB container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=recipes

# Application — SQLAlchemy connection string (host is "db" in docker-compose)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/recipes

# Auth — JWT signing key (generate a random string for production)
JWT_SECRET_KEY=change-me-in-production

# Auth — Google OAuth client ID (see README for setup instructions)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
